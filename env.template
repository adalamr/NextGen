# ============================================================
# AI Test Platform - Environment Configuration Template
# Copy this file to .env and fill in your values
# ============================================================

# Server
NODE_ENV=development
PORT=4000

# Database (PostgreSQL + pgvector)
DATABASE_URL=postgresql://platform:platform_secret@localhost:5432/platform_db
POSTGRES_DB=platform_db
POSTGRES_USER=platform
POSTGRES_PASSWORD=platform_secret

# Redis (BullMQ queues)
REDIS_URL=redis://localhost:6379
REDIS_HOST=localhost
REDIS_PORT=6379

# Authentication
JWT_SECRET=your-super-secret-jwt-key-minimum-32-characters
JWT_REFRESH_SECRET=your-refresh-secret-key-minimum-32-chars
JWT_EXPIRY=15m
JWT_REFRESH_EXPIRY=7d

# Security
# AES-256 key for encrypting per-project LLM API keys at rest
ENCRYPTION_KEY=32-character-encryption-key-here

# CORS
CORS_ORIGINS=http://localhost:3000

# ============================================================
# NOTE ON LLM CONFIGURATION
# ============================================================
# LLM credentials (AWS Bedrock endpoint, access key, model)
# are configured per-project by users via the Project Settings UI.
# They are encrypted with ENCRYPTION_KEY before being stored in
# the database. No platform-level LLM keys are required.
# ============================================================
